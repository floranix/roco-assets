        ],
        "query": {
          "name": "查询状态",
          "cmd": 0,
          "branches": [
            {
              "name": "最终奖励待手动领取",
              "message": "好感度已满，请手动领取最终奖励",
              "conditions": [
                {
                  "path": "angel.schedule",
                  "operator": "GTE",
                  "value": "100"
                },
                {
                  "path": "angel.received",
                  "operator": "EQ",
                  "value": "0"
                }
              ],
              "stopCurrentActivity": true
            },
            {
              "name": "今日已无可执行点位",
              "message": "今日 4 个爱心志愿点位已全部完成",
