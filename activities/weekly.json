              ],
              "stopCurrentActivity": true
            },
            {
              "name": "执行一个爱心志愿点位",
              "message": "开始处理一个未完成的爱心志愿点位",
              "conditions": [
                {
                  "path": "angel.schedule",
                  "operator": "LT",
                  "value": "100"
                },
                {
                  "path": "angel.received",
                  "operator": "EQ",
                  "value": "0"
                },
                {
                  "binding": "volunteerIndex",
                  "operator": "EXISTS",
                  "value": ""
                },
                {
                  "binding": "battleNpcId",
                  "operator": "EXISTS",
                  "value": ""
                }
              ],
              "combat": {
